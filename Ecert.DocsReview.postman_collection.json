            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"Comment\",\n  \"content\": \"Will fix the totals in the next version.\",\n  \"createdBy\": \"juan.author\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/documents/{{documentId}}/observations",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "documents",
                "{{documentId}}",
                "observations"
