              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"CorrectionRequest\",\n  \"content\": \"Update the totals on page 2 to match the annex.\",\n  \"createdBy\": \"maria.reviewer\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/documents/{{documentId}}/observations",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "documents",
                "{{documentId}}",
                "observations"
              ]
            },
            "description": "Records a CorrectionRequest on the current version."
          }
        },
        {
          "name": "List observations (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('includes the rejection reason and the new observations', function () {",
                  "  const types = pm.response.json().map(o => o.type);",
                  "  pm.expect(types).to.include('RejectionReason');",
                  "  pm.expect(types).to.include('Comment');",
                  "  pm.expect(types).to.include('CorrectionRequest');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/documents/{{documentId}}/observations",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "documents",
                "{{documentId}}",
                "observations"
              ]
            },
            "description": "All observations across every version, including the RejectionReason recorded by the 'Reject with reason' status transition."
          }
        },
        {
          "name": "Add rejection reason directly (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 400', function () { pm.response.to.have.status(400); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"RejectionReason\",\n  \"content\": \"Trying to record a rejection without rejecting.\",\n  \"createdBy\": \"maria.reviewer\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/documents/{{documentId}}/observations",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "documents",
                "{{documentId}}",
                "observations"
              ]
            },
            "description": "RejectionReason observations can only be created by rejecting the document via the status endpoint, so a reason always coincides with a rejection in the audit trail."
          }
        },
        {
          "name": "Register second document for state check (201)",
          "event": [
